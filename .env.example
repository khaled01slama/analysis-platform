# ── LLM Provider ─────────────────────────────────────────────────────
# Groq (primary) – get a key at https://console.groq.com/keys
GROQ_API_KEY=
GROQ_MODEL=llama-3.1-8b-instant

# Ollama (optional fallback – used only when langchain-groq is not installed)
# OLLAMA_MODEL=llama3.1:latest
# OLLAMA_BASE_URL=http://localhost:11434

# ── General ──────────────────────────────────────────────────────────
# LLM_TEMPERATURE=0.1
# LOG_LEVEL=INFO
# DEBUG=false
